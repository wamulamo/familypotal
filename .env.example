# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# みち・パパ・ママの固定ログイン（各1アカウント）
# メールは Supabase に登録するID、パスワードはここで設定したものを使う
FAMILY_MICHI_EMAIL=michi@family.local
FAMILY_MICHI_PASSWORD=your-michi-password
FAMILY_PAPA_EMAIL=papa@family.local
FAMILY_PAPA_PASSWORD=your-papa-password
FAMILY_MAMA_EMAIL=mama@family.local
FAMILY_MAMA_PASSWORD=your-mama-password

# Google Gemini API（学習に利用されない設定は API ポリシーで保証）
# https://ai.google.dev/gemini-api/docs/usage-policies
GEMINI_API_KEY=your-gemini-api-key

# YouTube Data API v3（チャンネルごと許可する場合のみ。未設定なら動画URLのみ許可）
# https://console.cloud.google.com/apis/library/youtube.googleapis.com で有効化しAPIキーを発行
# YOUTUBE_API_KEY=your-youtube-data-api-key
